generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  SELLER
  BOTH
}

/// Modo de uso activo de la cuenta. No es un permiso: las capacidades reales viven en UserRole.
enum UserMode {
  BUYER
  SELLER
}

enum SellerType {
  PERSONAL
  BUSINESS
}

enum Country {
  AR
  US
}

enum Currency {
  ARS
  USD
}

enum Locale {
  ES
  EN
}

enum RequestCategory {
  AUTOS
  INMOBILIARIA
}

enum OperationType {
  COMPRA
  ALQUILER
}

enum OfferStatus {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

enum RatingType {
  REVIEW
  NO_RESPONSE
}

/// Estados almacenados. INACTIVA, ARCHIVADA y PENDIENTE_DE_CONFIRMACION se derivan de lastBuyerActivityAt.
enum RequestStatus {
  ACTIVA
  NEGOCIANDO
  CERRADA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role            UserRole         @default(BUYER)
  activeMode      UserMode         @default(BUYER)
  sellerType      SellerType?
  sellerCategory  RequestCategory?
  country         Country
  locale          Locale
  currency        Currency
  avatarUrl       String?
  bio             String?
  businessName    String?
  phone           String?
  website         String?
  city            String?
  lastSellerFilters Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requests         Request[]
  offers           Offer[]
  ratingsGiven     Rating[] @relation("RatingsGiven")
  ratingsReceived  Rating[] @relation("RatingsReceived")
  savedSearches    SavedSearch[]
  savedRequests    SavedRequest[]
}

model SavedSearch {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  category  RequestCategory?
  filters   Json
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, name])
  @@index([userId, isDefault])
}

model SavedRequest {
  id        String   @id @default(cuid())
  sellerId  String
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([sellerId, requestId])
  @@index([sellerId, createdAt])
}

model Request {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     RequestCategory
  operation    OperationType   @default(COMPRA)
  title        String
  requirements String
  budget       Int
  budgetPeriod String?
  negotiable   Boolean         @default(true)
  currency     Currency
  location     String
  zone         String?
  bedrooms     Int?
  minSqm       Int?
  maxSqm       Int?
  country      Country
  imageUrls    String[]        @default([])
  carBrand     String?
  carModel     String?
  carColor     String?
  carYearMin   Int?
  maxMileage   Int?
  active       Boolean         @default(true)
  status               RequestStatus @default(ACTIVA)
  lastActivityAt       DateTime      @default(now())
  lastBuyerActivityAt  DateTime      @default(now())
  pausedAt             DateTime?
  closedAt             DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  offers Offer[]
  savedBy SavedRequest[]

  @@index([userId, active])
  @@index([country, active, lastBuyerActivityAt])
  @@index([category, active])
  @@index([category, country, carBrand, carModel])
  @@index([category, country, location, zone])
  @@index([category, country, bedrooms, minSqm, maxSqm])
}

model Offer {
  id                    String      @id @default(cuid())
  requestId             String
  request               Request     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sellerId              String
  seller                User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  price                 Int
  currency              Currency
  message               String
  imageUrls             String[]    @default([])
  status                OfferStatus @default(PENDIENTE)
  requestTitle          String
  requestBudget         Int
  requestBudgetPeriod   String?
  requestRequirements   String
  requestLocation       String
  createdAt             DateTime    @default(now())
  acceptedAt            DateTime?

  chat Chat?

  @@unique([requestId, sellerId])
  @@index([sellerId])
  @@index([requestId, status])
}

model Chat {
  id        String    @id @default(cuid())
  offerId   String    @unique
  offer     Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  fromRole  String
  text      String
  createdAt DateTime @default(now())

  @@index([chatId])
}

model Rating {
  id         String     @id @default(cuid())
  fromUserId String
  fromUser   User       @relation("RatingsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User       @relation("RatingsReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  offerId    String
  type       RatingType @default(REVIEW)
  stars      Int?
  comment    String?
  createdAt  DateTime   @default(now())

  @@unique([fromUserId, offerId])
  @@index([toUserId])
  @@index([toUserId, type])
}
