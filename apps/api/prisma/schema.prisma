generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  SELLER
  BOTH
  ADMIN
}

/// Modo de uso activo de la cuenta. No es un permiso: las capacidades reales viven en UserRole.
enum UserMode {
  BUYER
  SELLER
}

enum SubscriptionPlan {
  FREE
  PLUS
  ENTERPRISE
}

enum SellerType {
  PERSONAL
  BUSINESS
}

enum Country {
  AR
  US
}

enum Currency {
  ARS
  USD
}

enum Locale {
  ES
  EN
}

enum RequestCategory {
  AUTOS
  INMOBILIARIA
}

enum OperationType {
  COMPRA
  ALQUILER
}

enum OfferStatus {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

enum RatingType {
  REVIEW
  NO_RESPONSE
}

enum SecurityEvent {
  USER_REGISTERED
  LOGIN_SUCCESS
  LOGIN_FAILED
  PASSWORD_RESET_REQUESTED
  PASSWORD_CHANGED
  EMAIL_VERIFIED
  LOGOUT
  ADMIN_USER_BLOCKED
  ADMIN_USER_UNBLOCKED
  ADMIN_USER_EMAIL_VERIFIED
  ADMIN_OFFER_DELETED
  ADMIN_REQUEST_CLOSED
  ADMIN_REQUEST_REACTIVATED
  ADMIN_REQUEST_DELETED
  ADMIN_MESSAGE_DELETED
  ADMIN_REPORT_STATUS_CHANGED
  ADMIN_USER_UNSUSPENDED
  AUTO_REVIEW_TRIGGERED
  AUTO_HIDE_REQUEST
  AUTO_HIDE_OFFER
  AUTO_SUSPEND_USER
  AUTO_RESTORE_CONTENT
}

enum ReportReason {
  SPAM
  SCAM
  INAPPROPRIATE_CONTENT
  FAKE_OFFER
  ABUSIVE_BEHAVIOR
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum NotificationType {
  NEW_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
  NEW_MESSAGE
  REQUEST_EXPIRING
  REQUEST_INACTIVE
  REQUEST_CLOSED
  EMAIL_VERIFIED
  NEW_MATCHING_REQUEST
}

enum NotificationEntityType {
  REQUEST
  OFFER
  CHAT
  USER
}

/// Estados almacenados. INACTIVA, ARCHIVADA y PENDIENTE_DE_CONFIRMACION se derivan de lastBuyerActivityAt.
enum RequestStatus {
  ACTIVA
  NEGOCIANDO
  CERRADA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role            UserRole         @default(BUYER)
  activeMode      UserMode         @default(BUYER)
  sellerType      SellerType?
  sellerCategory  RequestCategory?
  country         Country
  locale          Locale
  currency        Currency
  avatarUrl       String?
  bio             String?
  businessName    String?
  phone           String?
  website         String?
  city            String?
  lastSellerFilters Json?
  emailVerified    Boolean   @default(false)
  emailVerifiedAt  DateTime?
  blocked          Boolean   @default(false)
  blockedAt        DateTime?
  blockedReason    String?
  suspended        Boolean   @default(false)
  suspendedAt      DateTime?
  suspendedReason  String?
  subscriptionPlan SubscriptionPlan @default(FREE)
  preferredMode        UserMode @default(BUYER)
  notificationPreferences Json?
  defaultAcceptMessage   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requests                  Request[]
  offers                    Offer[]
  ratingsGiven              Rating[] @relation("RatingsGiven")
  ratingsReceived           Rating[] @relation("RatingsReceived")
  savedSearches             SavedSearch[]
  savedRequests             SavedRequest[]
  emailVerificationTokens   EmailVerificationToken[]
  passwordResetTokens       PasswordResetToken[]
  refreshTokens             RefreshToken[]
  securityLogs              SecurityLog[]
  notifications             Notification[]
  reportsMade               Report[] @relation("ReportsMade")
  reportsAgainst            Report[] @relation("ReportsAgainst")
  reportsReviewed           Report[] @relation("ReportsReviewed")
  chatReadStates            ChatReadState[]

  @@index([blocked])
  @@index([suspended])
  @@index([role])
}

model Report {
  id                  String       @id @default(cuid())
  reporterId          String
  reporter            User         @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUserId      String?
  reportedUser        User?        @relation("ReportsAgainst", fields: [reportedUserId], references: [id], onDelete: SetNull)
  requestId           String?
  offerId             String?
  chatId              String?
  messageId           String?
  reason              ReportReason
  details             String?
  status              ReportStatus @default(PENDING)
  weight              Int          @default(1)
  resolvedByAdmin     Boolean      @default(false)
  autoTriggeredAction String?
  reporterIp          String?
  reporterUserAgent   String?
  createdAt           DateTime     @default(now())
  reviewedAt          DateTime?
  reviewedById        String?
  reviewedBy          User?        @relation("ReportsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reportedUserId])
  @@index([reporterId])
  @@index([requestId])
  @@index([offerId])
}

model Notification {
  id         String                  @id @default(cuid())
  userId     String
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  message    String
  entityId   String?
  entityType NotificationEntityType?
  read       Boolean                 @default(false)
  createdAt  DateTime                @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@index([userId, type, entityId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model SecurityLog {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  event     SecurityEvent
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([event, createdAt])
}

model SavedSearch {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  category  RequestCategory?
  filters   Json
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, name])
  @@index([userId, isDefault])
}

model SavedRequest {
  id        String   @id @default(cuid())
  sellerId  String
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([sellerId, requestId])
  @@index([sellerId, createdAt])
}

model Request {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     RequestCategory
  operation    OperationType   @default(COMPRA)
  title        String
  requirements String
  budget       Int
  budgetPeriod String?
  negotiable   Boolean         @default(true)
  currency     Currency
  location     String
  zone         String?
  bedrooms     Int?
  minSqm       Int?
  maxSqm       Int?
  country      Country
  imageUrls    String[]        @default([])
  carBrand     String?
  carModel     String?
  carColor     String?
  carYearMin   Int?
  maxMileage   Int?
  active       Boolean         @default(true)
  hiddenByModeration       Boolean @default(false)
  moderationReviewRequired Boolean @default(false)
  status               RequestStatus @default(ACTIVA)
  lastActivityAt       DateTime      @default(now())
  lastBuyerActivityAt  DateTime      @default(now())
  pausedAt             DateTime?
  closedAt             DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  offers Offer[]
  savedBy SavedRequest[]

  @@index([userId, active])
  @@index([country, active, lastBuyerActivityAt])
  @@index([country, active, category, lastBuyerActivityAt])
  @@index([category, active])
  @@index([category, country, carBrand, carModel])
  @@index([category, country, location, zone])
  @@index([category, country, bedrooms, minSqm, maxSqm])
}

model Offer {
  id                    String      @id @default(cuid())
  requestId             String
  request               Request     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sellerId              String
  seller                User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  price                 Int
  currency              Currency
  message               String
  imageUrls             String[]    @default([])
  status                OfferStatus @default(PENDIENTE)
  dismissedBySeller     Boolean     @default(false)
  hiddenByModeration       Boolean  @default(false)
  moderationReviewRequired Boolean  @default(false)
  requestTitle          String
  requestBudget         Int
  requestBudgetPeriod   String?
  requestRequirements   String
  requestLocation       String
  createdAt             DateTime    @default(now())
  acceptedAt            DateTime?

  chat Chat?

  @@unique([requestId, sellerId])
  @@index([sellerId])
  @@index([sellerId, dismissedBySeller, createdAt])
  @@index([requestId, status])
}

model Chat {
  id        String    @id @default(cuid())
  offerId   String    @unique
  offer     Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  messages  Message[]
  readStates ChatReadState[]
  createdAt DateTime  @default(now())
}

model ChatReadState {
  id         String   @id @default(cuid())
  chatId     String
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@unique([chatId, userId])
  @@index([userId])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  fromRole  String
  text      String
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
}

model Rating {
  id         String     @id @default(cuid())
  fromUserId String
  fromUser   User       @relation("RatingsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User       @relation("RatingsReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  offerId    String
  type       RatingType @default(REVIEW)
  stars      Int?
  comment    String?
  createdAt  DateTime   @default(now())

  @@unique([fromUserId, offerId])
  @@index([toUserId])
  @@index([toUserId, type])
}
