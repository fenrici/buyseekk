# API (local)
DATABASE_URL="postgresql://buyseekk:buyseekk@localhost:5432/buyseekk?schema=public"
REDIS_URL="redis://localhost:6379"
# Lanzamiento por país: US = solo Estados Unidos (default). MULTI solo en web (dev).
LAUNCH_COUNTRY="US"
# Lanzamiento gratuito: true = sin límites de plan. En producción con usuarios reales usar false.
PLUS_FEATURES_UNLOCKED="true"
# URL pública de la web (emails de auth y notificaciones — obligatorio en producción)
WEB_URL="http://localhost:3000"
# Emails automáticos de notificaciones (ofertas, mensajes, alertas)
NOTIFICATION_EMAILS_ENABLED="true"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"
JWT_EXPIRES_IN="15m"
EMAIL_PROVIDER="console"
# Para enviar emails reales en Railway:
#   EMAIL_PROVIDER="resend"
#   EMAIL_API_KEY="re_..."
#   EMAIL_FROM="Buyseekk <noreply@tudominio.com>"
# Sin dominio propio (solo pruebas):
#   EMAIL_FROM="Buyseekk <onboarding@resend.dev>"
#   EMAIL_SANDBOX_TO="tu-email@gmail.com"
EMAIL_FROM="Buyseekk <onboarding@resend.dev>"
EMAIL_SANDBOX_TO="tu-email@gmail.com"
EMAIL_API_KEY=""
# Storage: local (dev) | r2 (producción — obligatorio en Railway)
STORAGE_PROVIDER="local"
# STORAGE_PROVIDER="r2"
# STORAGE_PUBLIC_URL="https://cdn.tudominio.com"
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"
# Observabilidad (opcional)
# SENTRY_DSN="https://...@sentry.io/..."
# Rate limiting — overrides opcionales (requests por 60s)
# THROTTLE_LOGIN_LIMIT=10
# THROTTLE_REGISTER_LIMIT=5
# THROTTLE_UPLOAD_LIMIT=15
# THROTTLE_OFFER_LIMIT=30
# THROTTLE_CHAT_LIMIT=60
# THROTTLE_SEARCH_LIMIT=90
# THROTTLE_WRITE_LIMIT=10
# THROTTLE_DEFAULT_LIMIT=120

# Web (local) — copiar a apps/web/.env.local
NEXT_PUBLIC_LAUNCH_COUNTRY="US"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SUPPORT_EMAIL="support@buyseekk.com"
# Solo desarrollo local con seed (nunca en producción)
NEXT_PUBLIC_ENABLE_DEMO_LOGIN="true"
# Hostname del CDN de imágenes (sin https://) para next/image
# NEXT_PUBLIC_STORAGE_HOST="cdn.tudominio.com"
# Observabilidad web (opcional)
# NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
NEXT_PUBLIC_APP_VERSION="0.1.0"

# --- Producción (Railway API) — configurar vos ---
# DATABASE_URL     → referencia automática al plugin Postgres
# JWT_SECRET       → openssl rand -base64 32  (mín. 16 caracteres)
# NODE_ENV         → production
# CORS_ORIGIN      → https://tu-app.vercel.app
# WEB_URL          → https://tu-app.vercel.app  (mismo dominio que CORS_ORIGIN)
# PLUS_FEATURES_UNLOCKED → false (aplicar límites Free) o true (lanzamiento gratis)
# LAUNCH_COUNTRY   → US
# EMAIL_PROVIDER   → resend (+ EMAIL_API_KEY, EMAIL_FROM verificado)
# STORAGE_PROVIDER → r2 (+ R2_* y STORAGE_PUBLIC_URL)
# REDIS_URL        → obligatorio si escalás a 2+ réplicas API
# SENTRY_DSN       → opcional pero recomendado
# PORT             → lo setea Railway (no tocar)

# --- Producción (Vercel Web) — configurar vos ---
# NEXT_PUBLIC_API_URL → https://tu-api.up.railway.app  (sin /api al final)
# NEXT_PUBLIC_SITE_URL → https://tu-app.vercel.app
# NEXT_PUBLIC_LAUNCH_COUNTRY → US
# NEXT_PUBLIC_SUPPORT_EMAIL → support@buyseekk.com
# NEXT_PUBLIC_ENABLE_DEMO_LOGIN → no setear (o false)
# NEXT_PUBLIC_STORAGE_HOST → hostname del CDN R2
# NEXT_PUBLIC_SENTRY_DSN → opcional
