# API (local)
DATABASE_URL="postgresql://buyseekk:buyseekk@localhost:5432/buyseekk?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"
JWT_EXPIRES_IN="15m"
EMAIL_PROVIDER="console"
# Para enviar emails reales: EMAIL_PROVIDER="resend"
# Sin dominio propio, usá el sandbox de Resend:
EMAIL_FROM="Buyseek <onboarding@resend.dev>"
# Tu email de cuenta Resend (obligatorio mientras no tengas dominio verificado)
EMAIL_SANDBOX_TO="tu-email@gmail.com"
EMAIL_API_KEY=""
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# Web (local) — copiar a apps/web/.env.local
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Producción (Railway API) ---
# DATABASE_URL     → referencia automática al plugin Postgres
# JWT_SECRET       → openssl rand -base64 32  (mín. 16 caracteres)
# NODE_ENV         → production
# CORS_ORIGIN      → https://tu-app.vercel.app
# PORT             → lo setea Railway (no tocar)

# --- Producción (Vercel Web) ---
# NEXT_PUBLIC_API_URL → https://tu-api.up.railway.app  (sin /api al final)
