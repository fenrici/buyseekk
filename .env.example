# API (local)
DATABASE_URL="postgresql://buyseekk:buyseekk@localhost:5432/buyseekk?schema=public"
REDIS_URL="redis://localhost:6379"
# Lanzamiento por país: US = solo Estados Unidos (default). MULTI = AR + US (dev/futuro).
LAUNCH_COUNTRY="US"
# Lanzamiento gratuito: true = sin límites de plan. En producción con usuarios reales usar false.
PLUS_FEATURES_UNLOCKED="true"
# URL pública de la web (emails de notificación y links)
WEB_URL="http://localhost:3000"
# Emails automáticos de notificaciones (ofertas, mensajes, alertas)
NOTIFICATION_EMAILS_ENABLED="true"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"
JWT_EXPIRES_IN="15m"
EMAIL_PROVIDER="console"
# Para enviar emails reales en Railway/Vercel:
#   EMAIL_PROVIDER="resend"
#   EMAIL_API_KEY="re_..."          ← obligatorio con resend
#   EMAIL_FROM="Buyseek <noreply@tudominio.com>"
# Sin dominio propio (solo pruebas):
#   EMAIL_FROM="Buyseek <onboarding@resend.dev>"
#   EMAIL_SANDBOX_TO="tu-email@gmail.com"
EMAIL_FROM="Buyseek <onboarding@resend.dev>"
# Tu email de cuenta Resend (obligatorio mientras no tengas dominio verificado)
EMAIL_SANDBOX_TO="tu-email@gmail.com"
EMAIL_API_KEY=""
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# Web (local) — copiar a apps/web/.env.local
# Default US si se omite. MULTI habilita Argentina + selector de país.
NEXT_PUBLIC_LAUNCH_COUNTRY="US"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SUPPORT_EMAIL="support@buyseekk.com"

# --- Producción (Railway API) ---
# DATABASE_URL     → referencia automática al plugin Postgres
# JWT_SECRET       → openssl rand -base64 32  (mín. 16 caracteres)
# NODE_ENV         → production
# CORS_ORIGIN      → https://tu-app.vercel.app
# WEB_URL          → https://tu-app.vercel.app
# PLUS_FEATURES_UNLOCKED → false (aplicar límites Free)
# LAUNCH_COUNTRY     → US (mercado único en lanzamiento)
# EMAIL_PROVIDER   → resend
# PORT             → lo setea Railway (no tocar)

# --- Producción (Vercel Web) ---
# NEXT_PUBLIC_API_URL → https://tu-api.up.railway.app  (sin /api al final)
# NEXT_PUBLIC_SITE_URL → https://tu-app.vercel.app
# NEXT_PUBLIC_LAUNCH_COUNTRY → US
# NEXT_PUBLIC_SUPPORT_EMAIL → support@buyseekk.com
